<Window x:Class="P2PFT_Cs.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change Vault Password"
        Width="400" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BgBodyBrush}"
        ShowInTaskbar="False">

    <Border Background="{StaticResource BgCardBrush}"
            CornerRadius="10" Padding="36,32" Margin="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.10" Color="Black"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="🔑" FontSize="36"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Change Vault Password"
                       FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,6"/>
            <TextBlock Text="Re-encrypts your identity profile and all vault files."
                       FontSize="12" TextWrapping="Wrap" TextAlignment="Center"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,20"/>

            <!-- Error banner -->
            <Border x:Name="ErrorBanner"
                    Background="{StaticResource ErrorBgBrush}"
                    BorderBrush="{StaticResource ErrorBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="12,10" Margin="0,0,0,14"
                    Visibility="Collapsed">
                <TextBlock x:Name="ErrorText"
                           Foreground="{StaticResource ErrorBrush}"
                           FontSize="12" TextWrapping="Wrap"/>
            </Border>

            <TextBlock Text="Current Password" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="CurrentPassword"
                         Style="{StaticResource InputPassword}" Margin="0,0,0,14"/>

            <TextBlock Text="New Password" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="NewPassword"
                         Style="{StaticResource InputPassword}" Margin="0,0,0,14"/>

            <TextBlock Text="Confirm New Password" FontSize="12" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ConfirmPassword"
                         Style="{StaticResource InputPassword}" Margin="0,0,0,22"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0"
                        Style="{StaticResource BtnSmall}"
                        Background="{StaticResource BgInputBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderBrush="{StaticResource AppBorderBrush}"
                        BorderThickness="1"
                        Padding="0,10" FontSize="13"
                        Content="Cancel"
                        Click="OnCancel"/>
                <Button Grid.Column="2"
                        x:Name="ConfirmBtn"
                        Style="{StaticResource BtnPrimary}"
                        Padding="0,10" FontSize="13" FontWeight="SemiBold"
                        Content="Change Password"
                        Click="OnConfirm"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
